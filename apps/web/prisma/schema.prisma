  providerInfo   Json?         @map("provider_info")
  status         String        @default("SENT")
  errorMessage   String?       @map("error_message")
  createdAt      DateTime      @default(now()) @map("created_at")
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  notification   Notification? @relation(fields: [notificationId], references: [id])
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([channel, status])
  @@map("notification_delivery_logs")
}

model WebhookEvent {
  id          String   @id @default(uuid())
  externalId  String   @unique @map("external_id")
  eventType   String   @map("event_type")
  platform    String
  payload     Json?
  processedAt DateTime @default(now()) @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([platform])
  @@index([eventType])
  @@map("webhook_events")
}

model ProjectToService {
  A        String
  B        String
  projects Project @relation(fields: [A], references: [id], onDelete: Cascade)
  services Service @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_ProjectToService_AB_pkey")
  @@index([B], map: "_ProjectToService_B_index")
  @@map("_ProjectToService")
}

// Social profile for dynamic platform mockups
model SocialProfile {
  id          String   @id @default(uuid())
  platform    String   // "instagram" | "tiktok" | "facebook"
  username    String
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?
  website     String?
  followersCount Int   @default(0) @map("followers_count")
  followingCount Int   @default(0) @map("following_count")
  emoji       String?  @default("😎")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([platform])
  @@map("social_profiles")
}
