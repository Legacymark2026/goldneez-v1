generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_EXTERNAL_URL")
}

model User {
  id                      String                    @id @default(uuid())
  name                    String?
  email                   String?                   @unique
  emailVerified           DateTime?                 @map("email_verified")
  image                   String?
  passwordHash            String?                   @map("password_hash")
  firstName               String?                   @map("first_name")
  lastName                String?                   @map("last_name")
  phone                   String?
  role                    String                    @default("guest")
  mfaEnabled              Boolean                   @default(false) @map("mfa_enabled")
  mfaSecret               String?                   @map("mfa_secret")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  deactivatedAt           DateTime?                 @map("deactivated_at")
  adminNotes              String?                   @map("admin_notes")
  backupCodes             Json?                     @map("backup_codes")
  customTag               String?                   @map("custom_tag")
  jobTitle                String?                   @map("job_title")
  globalRole              String                    @default("client_user") @map("global_role")
  accounts                Account[]
  agentConversations      AgentConversation[]
  annotations             Annotation[]
  apiKeys                 ApiKey[]
  assetAnnotations        AssetAnnotation[]
  assetCollections        AssetCollection[]
  assetVersions           AssetVersion[]
  claimedBounties         Bounty[]                  @relation("BountyClaimer")
  createdBounties         Bounty[]                  @relation("BountyCreator")
  approvedCampaigns       Campaign[]                @relation("ApprovedCampaigns")
  commissionPayments      CommissionPayment[]       @relation("UserCommissionPayments")
  commissionRules         CommissionRule[]          @relation("UserCommissionRules")
  invitedUsers            CompanyUser[]             @relation("InvitedBy")
  companies               CompanyUser[]
  assignedConversations   Conversation[]
  crmActivities           CRMActivity[]
  stageHistoryChanges     DealStageHistory[]        @relation("StageHistoryUser")
  assignedDeals           Deal[]                    @relation("AssignedDeals")
  eventParticipations     EventParticipant[]
  organizedEvents         Event[]                   @relation("EventOrganizer")
  approvedExpenses        Expense[]                 @relation("ExpenseApprover")
  createdExpenses         Expense[]                 @relation("ExpenseCreator")
  kanbanAnnotations       KanbanAssetAnnotation[]   @relation("AnnotationAuthor")
  kanbanAuditLogs         KanbanAuditLog[]          @relation("KanbanAuditActor")
  kanbanComments          KanbanComment[]           @relation("KanbanCommentAuthor")
  kanbanSubtasks          KanbanSubtask[]           @relation("KanbanSubtaskCreator")
  assignedKanbanTasks     KanbanTask[]              @relation("KanbanTaskAssignee")
  createdKanbanTasks      KanbanTask[]              @relation("KanbanTaskCreator")
  marketingEvents         MarketingEvent[]
  NotificationDeliveryLog NotificationDeliveryLog[]
  Notification            Notification[]
  payrollAuditLogs        PayrollAuditLog[]         @relation("PayrollAuditor")
  posts                   Post[]
  proposals               Proposal[]
  readingList             ReadingListItem[]
  resourcePermissions     ResourcePermission[]
  salesGoals              SalesGoal[]               @relation("UserSalesGoals")
  sessions                Session[]
  socialPostComments      SocialPostComment[]
  socialPostLogs          SocialPostLog[]
  approvedSocialPosts     SocialPost[]              @relation("SocialPostApprover")
  socialPosts             SocialPost[]              @relation("SocialPostAuthor")
  assignedTasks           Task[]                    @relation("TaskAssignee")
  createdTasks            Task[]                    @relation("TaskCreator")
  timeEntries             TimeEntry[]
  approvedTimeOffs        TimeOffRequest[]          @relation("TimeOffApprover")
  approvedTimesheets      Timesheet[]               @relation("TimesheetApprover")
  activityLogs            UserActivityLog[]
  profile                 UserProfile?

  @@index([role])
  @@index([email])
  @@map("users")
}

model RoleConfig {
  id            String   @id @default(uuid())
  roleName      String   @unique @map("role_name")
  allowedRoutes Json     @default("[]") @map("allowed_routes")
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([roleName])
  @@map("role_configs")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  module          String
  description     String?
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model Role {
  id          String           @id @default(uuid())
  companyId   String           @map("company_id")
  name        String
  description String?
  isDefault   Boolean          @default(false) @map("is_default")
  isActive    Boolean          @default(true) @map("is_active")
  priority    Int              @default(0)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       CompanyUser[]
  permissions RolePermission[]
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("roles")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model ResourcePermission {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  companyId    String   @map("company_id")
  resourceType String
  resourceId   String   @map("resource_id")
  permission   String
  access       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, resourceType, resourceId, permission])
  @@index([userId, companyId])
  @@index([resourceType, resourceId])
  @@map("resource_permissions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model UserProfile {
  id               String  @id @default(uuid())
  userId           String  @unique @map("user_id")
  jobTitle         String? @map("job_title")
  department       String?
  bio              String?
  socialLinks      Json?   @default("{}") @map("social_links")
  preferences      Json?   @default("{\"theme\": \"system\", \"notifications\": {\"email\": true}}")
  metadata         Json?   @default("{}")
  googleAnalytics  Json?   @map("google_analytics_config")
  facebookPixel    Json?   @map("facebook_pixel_config")
  googleTagManager Json?   @map("google_tag_manager_config")
  hotjar           Json?   @map("hotjar_config")
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Company {
  id                      String                    @id @default(uuid())
  name                    String
  slug                    String                    @unique
  logoUrl                 String?                   @map("logo_url")
  industry                String?
  website                 String?
  subscriptionTier        String                    @default("free") @map("subscription_tier")
  subscriptionStatus      String                    @default("active") @map("subscription_status")
  createdAt               DateTime                  @default(now()) @map("created_at")
  defaultCompanySettings  Json?                     @map("default_settings")
  passwordPolicy          Json?                     @map("password_policy")
  stripeCustomerId        String?                   @map("stripe_customer_id")
  stripeSubscriptionId    String?                   @map("stripe_subscription_id")
  whiteLabeling           Json?                     @map("white_labeling")
  customObjectDefinitions CustomObjectDefinition[]
  abTests                 ABTest[]
  adSpends                AdSpend[]
  agentConfig             AgentConfig?
  agentConversations      AgentConversation[]
  aiAgents                AIAgent[]
  apiKeys                 ApiKey[]
  assetCollections        AssetCollection[]
  brandKit                BrandKit?
  campaignAssets          CampaignAsset[]
  campaignRules           CampaignRule[]
  campaigns               Campaign[]
  commissionPayments      CommissionPayment[]
  commissionRules         CommissionRule[]
  members                 CompanyUser[]
  conversations           Conversation[]
  automationRules         DealAutomationRule[]
  deals                   Deal[]
  emailSequences          EmailSequence[]
  emailTemplates          EmailTemplate[]
  employeeBenefits        EmployeeBenefit[]
  employees               Employee[]
  events                  Event[]
  expenseCategories       ExpenseCategory[]
  expenses                Expense[]
  experiments             Experiment[]
  financialAccounts       FinancialAccount[]
  inboxMacros             InboxMacro[]
  integrationConfigs      IntegrationConfig[]
  integrationLogs         IntegrationLog[]
  invoices                Invoice[]
  kanbanProjects          KanbanProject[]
  knowledgeBases          KnowledgeBase[]
  scoringRules            LeadScoringRule[]
  leads                   Lead[]
  marketingEvents         MarketingEvent[]
  NotificationDeliveryLog NotificationDeliveryLog[]
  notificationPrefs       NotificationPreference[]
  Notification            Notification[]
  payrolls                Payroll[]
  proposals               Proposal[]
  resourcePermissions     ResourcePermission[]
  roles                   Role[]
  salesGoals              SalesGoal[]
  servicePrices           ServicePrice[]
  shortLinks              ShortLink[]
  socialPosts             SocialPost[]
  tasks                   Task[]
  teams                   Team[]
  usageLogs               UsageLog[]
  webhooks                Webhook[]
  workflows               Workflow[]

  @@map("companies")
}

model ServicePrice {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  codigo_id        String?  @map("codigo_id")
  nombre_servicio  String
  categoria        String
  tipo_formato     String?  @map("tipo_formato")
  tiempo_estimado  String?  @map("tiempo_estimado")
  herramientas     String?
  descripcion      String
  precio_base      Float
  iva_porcentaje   Float    @default(19.0)
  retefuente_porc  Float    @default(11.0)
  reteiva_porc     Float    @default(2.85)
  ica_porc         Float    @default(0.6)
  precio_urgente   Float?
  isExpress        Boolean  @default(false)
  estado           String   @default("activo")
  orderIndex       Int      @default(0) @map("order_index")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  ica_valor        Float?   @default(0) @map("ica_valor")
  iva_valor        Float?   @default(0) @map("iva_valor")
  retefuente_valor Float?   @default(0) @map("retefuente_valor")
  reteiva_valor    Float?   @default(0) @map("reteiva_valor")
  subtotal         Float?   @default(0)
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("service_prices")
}

model BrandKit {
  id             String   @id @default(uuid())
  companyId      String   @unique @map("company_id")
  name           String   @default("Brand Kit")
  primaryColor   String   @default("#6D28D9") @map("primary_color")
  secondaryColor String   @default("#FFFFFF") @map("secondary_color")
  accentColor    String   @default("#10B981") @map("accent_color")
  logoUrl        String?  @map("logo_url")
  fontFamily     String   @default("Inter") @map("font_family")
  toneOfVoice    String   @default("professional") @map("tone_of_voice")
  brandValues    String[] @map("brand_values")
  targetAudience String?  @map("target_audience")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("brand_kits")
}

model CompanyUser {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  companyId      String   @map("company_id")
  permissions    Json?    @default("[]")
  invitedBy      String?  @map("invited_by")
  joinedAt       DateTime @default(now()) @map("joined_at")
  teamId         String?  @map("team_id")
  phoneExtension String?  @map("phone_extension")
  roleId         String?  @map("role_id")
  roleName       String   @default("member") @map("role_name")
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inviter        User?    @relation("InvitedBy", fields: [invitedBy], references: [id])
  role           Role?    @relation(fields: [roleId], references: [id])
  team           Team?    @relation(fields: [teamId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([roleName])
  @@index([roleId])
  @@map("company_users")
}

model Team {
  id            String                   @id @default(uuid())
  name          String
  description   String?
  path          String                   @default("/")
  level         Int                      @default(0)
  parentId      String?                  @map("parent_id")
  companyId     String                   @map("company_id")
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")
  maxHeadcount  Int?                     @map("max_headcount")
  monthlyBudget Float?                   @map("monthly_budget")
  permissions   CustomObjectPermission[]
  bounties      Bounty[]
  members       CompanyUser[]
  company       Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent        Team?                    @relation("TeamHierarchy", fields: [parentId], references: [id])
  children      Team[]                   @relation("TeamHierarchy")

  @@index([companyId])
  @@index([path])
  @@map("teams")
}

model CustomObjectDefinition {
  id                String                     @id @default(cuid())
  name              String
  label             String
  description       String?
  companyId         String
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  company           Company                    @relation(fields: [companyId], references: [id])
  fields            CustomObjectField[]
  permissions       CustomObjectPermission[]
  relationshipsFrom CustomObjectRelationship[] @relation("RelationshipFrom")
  relationshipsTo   CustomObjectRelationship[] @relation("RelationshipTo")
  records           CustomObjectRecord[]

  @@unique([companyId, name])
}

model CustomObjectField {
  id           String                 @id @default(cuid())
  name         String
  label        String
  type         String
  required     Boolean                @default(false)
  options      String?
  definitionId String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  definition   CustomObjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
}

model CustomObjectRelationship {
  id        String                 @id @default(cuid())
  name      String
  type      String
  fromId    String
  toId      String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  from      CustomObjectDefinition @relation("RelationshipFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        CustomObjectDefinition @relation("RelationshipTo", fields: [toId], references: [id], onDelete: Cascade)
}

model CustomObjectPermission {
  id           String                 @id @default(cuid())
  teamId       String
  definitionId String
  canCreate    Boolean                @default(false)
  canRead      Boolean                @default(false)
  canUpdate    Boolean                @default(false)
  canDelete    Boolean                @default(false)
  definition   CustomObjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  team         Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, definitionId])
}

model CustomObjectRecord {
  id           String                 @id @default(uuid())
  definitionId String                 @map("definition_id")
  data         Json
  createdBy    String?                @map("created_by")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  definition   CustomObjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@map("custom_object_records")
}

model UserActivityLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  details   Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("user_activity_logs")
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  keyHash    String    @unique @map("key_hash")
  userId     String?   @map("user_id")
  companyId  String?   @map("company_id")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  createdBy  String?   @map("created_by")
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  prefix     String?   @map("prefix")
  scopes     String[]  @default([])
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Post {
  id              String      @id @default(uuid())
  title           String
  slug            String      @unique
  excerpt         String?
  content         String
  coverImage      String?     @map("cover_image")
  imageAlt        String?     @map("image_alt")
  published       Boolean     @default(false)
  metaTitle       String?     @map("meta_title")
  metaDescription String?     @map("meta_description")
  canonicalUrl    String?     @map("canonical_url")
  focusKeyword    String?     @map("focus_keyword")
  status          String      @default("draft")
  scheduledDate   DateTime?   @map("scheduled_date")
  authorId        String      @map("author_id")
  seriesId        String?     @map("series_id")
  seriesOrder     Int?        @map("series_order")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  categories      Category[]
  tags            Tag[]
  comments        Comment[]
  likes           PostLike[]
  views           PostView[]
  author          User        @relation(fields: [authorId], references: [id])
  series          PostSeries? @relation(fields: [seriesId], references: [id])
  faqs            Json?       @default("[]")

  @@index([authorId])
  @@index([seriesId])
  @@map("posts")
}

model Project {
  id                  String                @id @default(uuid())
  title               String
  slug                String                @unique
  description         String
  content             String?
  client              String?
  coverImage          String?               @map("cover_image")
  imageAlt            String?               @map("image_alt")
  gallery             Json?                 @default("[]")
  published           Boolean               @default(false)
  metaTitle           String?               @map("meta_title")
  metaDescription     String?               @map("meta_description")
  focusKeyword        String?               @map("focus_keyword")
  status              String                @default("draft")
  scheduledDate       DateTime?             @map("scheduled_date")
  featured            Boolean               @default(false)
  displayOrder        Int                   @default(0) @map("display_order")
  startDate           DateTime?             @map("start_date")
  endDate             DateTime?             @map("end_date")
  testimonial         String?
  results             Json?                 @default("[]")
  projectUrl          String?               @map("project_url")
  categoryId          String?               @map("category_id")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  clientLogo          String?               @map("client_logo")
  pdfUrl              String?               @map("pdf_url")
  private             Boolean               @default(false)
  seoScore            Int                   @default(0)
  team                Json?                 @default("[]")
  techStack           Json?                 @default("[]")
  videoUrl            String?               @map("video_url")
  ProjectToProjectTag ProjectToProjectTag[]
  ProjectToService    ProjectToService[]
  views               ProjectView[]
  category            ProjectCategory?      @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@map("projects")
}

model ProjectCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  projects    Project[]

  @@map("project_categories")
}

model ProjectTag {
  id                  String                @id @default(uuid())
  name                String                @unique
  ProjectToProjectTag ProjectToProjectTag[]

  @@map("project_tags")
}

model ProjectView {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  ipHash    String   @map("ip_hash")
  userAgent String?  @map("user_agent")
  referer   String?
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, ipHash, createdAt])
  @@index([projectId])
  @@index([createdAt])
  @@map("project_views")
}

model Service {
  id               String             @id @default(uuid())
  name             String
  slug             String             @unique
  icon             String?
  description      String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  ProjectToService ProjectToService[]

  @@map("services")
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[]

  @@map("tags")
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  posts Post[]

  @@map("categories")
}

model Workflow {
  id            String              @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean             @default(false) @map("is_active")
  triggerType   String              @map("trigger_type")
  triggerConfig Json                @map("trigger_config")
  steps         Json
  companyId     String              @map("company_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  executions    WorkflowExecution[]
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("workflows")
}

model WorkflowExecution {
  id          String    @id @default(uuid())
  status      String
  logs        Json?
  workflowId  String    @map("workflow_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  currentStep Int       @default(0) @map("current_step")
  resumeAt    DateTime? @map("resume_at")
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
  @@map("workflow_executions")
}

model Bounty {
  id           String   @id @default(uuid())
  title        String
  description  String?
  rewardAmount Float    @map("reward_amount")
  status       String   @default("OPEN")
  teamId       String   @map("team_id")
  createdBy    String   @map("created_by")
  claimedBy    String?  @map("claimed_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  claimer      User?    @relation("BountyClaimer", fields: [claimedBy], references: [id])
  creator      User     @relation("BountyCreator", fields: [createdBy], references: [id])
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([status])
  @@map("bounties")
}

model PostView {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  ipHash    String   @map("ip_hash")
  userAgent String?  @map("user_agent")
  referer   String?
