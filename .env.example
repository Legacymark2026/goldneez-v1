# ─────────────────────────────────────────────────
#  GOLDNEEZ — Environment Variables Template
#  Copy this file to .env.local and fill in values
#  NEVER commit .env.local to git
# ─────────────────────────────────────────────────

# ── APP ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://goldneez.tech
NEXTAUTH_URL=https://goldneez.tech
NEXTAUTH_SECRET=your-super-secret-random-string-min-32-chars

# ── DATABASE ──────────────────────────────────────
# PostgreSQL connection (separate DB from agency-v1!)
# Example: postgresql://goldneez_user:password@localhost:5432/goldneez_db
POSTGRES_EXTERNAL_URL=postgresql://USER:PASSWORD@HOST:5432/goldneez_db
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/goldneez_db

# ── PAYMENTS — STRIPE ─────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# For testing:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── PAYMENTS — MERCADOPAGO ────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
MP_CLIENT_ID=...
MP_CLIENT_SECRET=...
MP_WEBHOOK_SECRET=your-mp-webhook-secret
# Notification URL for MP webhooks
MP_NOTIFICATION_URL=https://goldneez.tech/api/payments/mercadopago/webhook

# ── MEDIA — CLOUDINARY ────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ── EMAIL — RESEND ────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@goldneez.tech
EMAIL_FROM_NAME=GOLDNEEZ

# ── AUTH PROVIDERS (optional) ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── ANALYTICS ─────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
NEXT_PUBLIC_FB_PIXEL_ID=...

# ── AI (optional) ─────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ── SHIPPING (optional) ───────────────────────────
# Integrate with Servientrega, Coordinadora, etc.
SHIPPING_API_KEY=
SHIPPING_API_URL=

# ── INTERNAL ──────────────────────────────────────
# Port for this app on the VPS (agency-v1 uses 3000)
PORT=3001
NODE_ENV=production
